        "./skills/synapse-migration",
        "./skills/hdinsight-migration",
        "./skills/e2e-medallion-architecture"
      ],
      "agents": [
        "./agents/FabricAdmin.agent.md",
        "./agents/FabricDataEngineer.agent.md",
        "./agents/FabricAppDev.agent.md",
        "./agents/FabricIQ.agent.md"
      ],
      "mcpServers": {
        "FabricIQ": {
          "type": "http",
          "url": "https://api.fabric.microsoft.com/v1/mcp/fabricaihub/integrations/m365",
          "headers": {
            "X-VARIANTS": "Fabric.Routing.LargeModelJMESPath"
          },
          "tools": [
            "DiscoverArtifacts",
            "GetReportMetadata",
            "GetSemanticModelSchema",
            "ValueSearch",
            "ExecuteQuery",
            "ResolveReportIdFromUrl"
          ]
        }
      },
      "repository": "https://github.com/microsoft/skills-for-fabric",
      "keywords": [
        "fabric",
        "microsoft-fabric",
        "medallion",
        "data-warehouse",
        "lakehouse",
